<?xml version="1.0" encoding="UTF-8"?>
<app xmlns="https://sp1rit.arpa/pixiewood/"
     xmlns:meta="https://specifications.freedesktop.org/metainfo/1.0">
  <metainfo vercalc="sem121010">
    <meta:component type="desktop-application">
      <meta:id>org.roojs.webkitgtk.androidbrowser</meta:id>
      <meta:name>webkitgtk-android Browser</meta:name>
      <meta:summary>Phase 2 GTK + Android System WebView embed</meta:summary>
      <meta:metadata_license>CC0-1.0</meta:metadata_license>
      <meta:project_license>LGPL-3.0-or-later</meta:project_license>
      <meta:description>
        <meta:p>
          Minimal browser chrome over Android System WebView, embedded in a
          GTK 4 Android activity (default https://roojs.com/).
        </meta:p>
      </meta:description>
      <meta:requires>
        <meta:internet>always</meta:internet>
      </meta:requires>
      <meta:branding>
        <meta:color type="primary" scheme_preference="light">#3584e4</meta:color>
        <meta:color type="primary" scheme_preference="dark">#1c71d8</meta:color>
      </meta:branding>
      <meta:releases>
        <meta:release version="0.1.0" date="2026-07-21"/>
      </meta:releases>
    </meta:component>
  </metainfo>
  <style>
    <theme name="adw"/>
    <icon type="generate">
      <drawable
        target="foreground"
        type="avd"
        path="src://android/icon-foreground.xml"/>
      <color target="background">#ffffff</color>
    </icon>
  </style>
  <dependencies>
    <glib>
      <patch>hack</patch>
    </glib>
    <fontconfig/>
    <gtk/>
    <libadwaita/>
    <nghttp2/>
    <sqlite3/>
    <libsoup/>
  </dependencies>
  <build target="webkitgtk-android-browser">
    <configure-options>
      <option>-Dandroid_browser=true</option>
      <option>-Dandroid_hello=false</option>
    </configure-options>
    <architectures>
      <arch>aarch64</arch>
    </architectures>
  </build>
</app>
